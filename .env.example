# Supabase / PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Optional: Google Drive API service account key path
GOOGLE_SERVICE_ACCOUNT_KEY=path/to/service-account.json

# Gemini API key (needed for Part 2 — not required for Part 1)
GEMINI_API_KEY=your-gemini-api-key

# Summarization model (change to gemini-2.5-pro or gemini-3-flash etc.)
# SUMMARIZER_MODEL=gemini-2.5-flash

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

